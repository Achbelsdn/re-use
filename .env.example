# Supabase (Pour générer les liens de téléchargement sécurisés)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5c...

# FedaPay (Pour le paiement Mobile Money)
# Utilise ta clé secrète Sandbox pour les tests (sk_sandbox_...), puis Live en prod (sk_live_...)
FEDAPAY_SECRET_KEY=sk_sandbox_xxxxxxxxxxxxxxxxxxxx

# Resend (Pour l'envoi de l'email avec le lien de téléchargement)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# (Optionnel) FedaPay Webhook Secret - Si tu vérifies la signature des webhooks
FEDAPAY_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxx

# Mot de passe administrateur pour accéder au Dashboard /admin
ADMIN_PASSWORD=choisis-un-mot-de-passe-fort-ici
